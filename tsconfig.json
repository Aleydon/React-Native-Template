{
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "jest", "@testing-library/react-native"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "jest.config.js",
    "tailwind.config.js",
    "metro.config.js",
    "babel.config.js",
    "src/**/*",
    "src/__tests__/**/*",
    ".jest/jest.setup.js",
    "src/**/*",
    "tests/**/*"
  ],
  "extends": "expo/tsconfig.base"
}
